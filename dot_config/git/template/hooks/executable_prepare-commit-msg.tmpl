#!/bin/sh
COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2
CUSTOM_HEADER="# This is an autogenerated commit message"
CUSTOM_FOOTER="# powered by github.com/burgr033/autoCommit"

if [[ -z "$COMMIT_SOURCE" ]]; then
{{- if eq .chezmoi.os "windows" }}
    autoCommit.exe -msgfile $COMMIT_MSG_FILE -header "$CUSTOM_HEADER" -footer "$CUSTOM_FOOTER"
{{- end }}
{{- if ne .chezmoi.os "windows" }}
    autoCommit -msgfile $COMMIT_MSG_FILE -header "$CUSTOM_HEADER" -footer "$CUSTOM_FOOTER"
{{- end}}
fi
