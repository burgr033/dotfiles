# -*-mode:conf-toml-*- vim:ft=toml
{{- $shell := "fish"}}
{{- $chassisType := "desktop" }}
{{- $gpgkeyAnswer := "personal" }}
{{- $allProfiles := list "common" -}}
{{- $distro := (.chezmoi.os) -}}
{{- if eq $distro "linux" -}}
    {{- if get .chezmoi.osRelease "idLike" -}}
        {{- $distro = .chezmoi.osRelease.idLike -}}
    {{- else -}}
        {{- $distro = .chezmoi.osRelease.id -}}
    {{- end -}}
{{- end -}}

{{- if eq .chezmoi.os "linux" }}
{{- $chassisType = (output "hostnamectl" "--json=short" | mustFromJson).Chassis }}
{{- if eq $chassisType "container" }}
{{- $allProfiles = list "common" }}
{{- if ( and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft")) }}
{{- $allProfiles = append $allProfiles "wsl" }}
{{- $allProfiles = append $allProfiles "work" }}
{{- end}}
{{- $allProfiles = append $allProfiles "docker" }}
{{- else if eq $distro "ubuntu" }}
{{- $allProfiles = list "common" }}
{{- else if eq $distro "arch" }}
{{- $allProfiles = append $allProfiles "gaming-desktop" }}
{{- $allProfiles = append $allProfiles "hypr-desktop" }}
{{- if or (eq $chassisType "convertible") (eq $chassisType "laptop") }}
{{- $allProfiles = append $allProfiles "mobile" }}
{{- end}}

{{- $allProfiles = append $allProfiles "study" }}
{{- $allProfiles = append $allProfiles "media" }}
{{- $allProfiles = append $allProfiles "pentesting" }}
{{- $allProfiles = append $allProfiles "docker" }}
{{- $allProfiles = append $allProfiles "work" }}
{{- end }}
{{- else if eq .chezmoi.os "windows" }}
{{- $shell = "pwsh" }}
{{- $chassisType = (output "powershell.exe" "-NoProfile" "-NonInteractive" "-Command" "if ((Get-CimInstance -Class Win32_Battery | Measure-Object).Count -gt 0) { Write-Output 'laptop' } else { Write-Output 'desktop' }") | trim }}
{{- $allProfiles = append $allProfiles "desktop" }}
{{- $allProfiles = append $allProfiles "study" }}
{{- $allProfiles = append $allProfiles "office" }}
{{- $allProfiles = append $allProfiles "gaming" }}
{{- end }}

# ----------------------------------------------------------------------------------

[edit]
command = "nvim"
{{- if lookPath "delta" }}
[diff]
command = "delta"
pager = "delta"
{{- end}}
{{- if lookPath "nvim" }}

[merge]
command = "nvim"
args = [
    "-d",
    {{ printf "%q" "{{ .Destination }}" }},
    {{ printf "%q" "{{ .Source }}" }},
    {{ printf "%q" "{{ .Target }}" }},
]
{{- end}}

[cd]
command = {{ $shell | quote }}

[data]
{{- $name := promptStringOnce . "name" "Name" "sb"}}
{{- $email := promptStringOnce . "email" "Email" "burgr@posteo.de"}}
name =  {{  $name | quote }}
distro = {{ $distro | quote}}
email = {{  $email | quote }}
shell = {{  $shell | quote }}
{{-  $profiles := promptMultichoiceOnce . "profiles" "What profiles should be enabled" $allProfiles }}
profiles = {{ $profiles | toToml }}
{{- $gpgkeyList := list "personal" "work" -}}
{{- $gpgkeyAnswer := promptChoiceOnce . "gpgkey" "What GPG should we install?" $gpgkeyList}}
{{- if eq $gpgkeyAnswer "work"}}
gpgkey = "83297FC845136CEC5D204EAB2FC883E6A65782EC"
{{- else}}
gpgkey = "BDE652404B6095EB4FE11A1A1707363660BFF7D7"
{{- end}}
{{- if ( and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft")) }}
isWSL = true
{{- else }}
isWSL = false
{{- end }}
{{- if ( or (eq $chassisType "container") (eq $chassisType "vm")) }}
isHeadless = true 
{{- else }}
isHeadless = false 
{{- end}}
{{- if eq (len $profiles) 0}}
manualSetup = true 
{{- else }}
manualSetup = false 
{{- end}}
chassisType = {{-  $chassisType | quote }}
